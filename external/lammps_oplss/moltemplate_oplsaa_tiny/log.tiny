LAMMPS (4 Jul 2026)
include "system.in.init"
atom_style full
units real
bond_style harmonic
angle_style harmonic
dihedral_style opls
improper_style cvff
pair_style lj/charmm/coul/long 9.0 11.0
pair_modify mix geometric
special_bonds lj/coul 0.0 0.0 0.5
kspace_style pppm 0.0001

read_data "system.data"
